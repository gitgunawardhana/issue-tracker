PORT=5000
MONGODB_URI=mongodb://localhost:27017/issue-tracker
JWT_SECRET=your-super-secret-access-token-key
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:5173

# 'production' enables Secure cookies; 'development' (or unset) allows non-HTTPS
NODE_ENV=development

# Set to 'true' ONLY when frontend and backend are on different sites in production
# (requires HTTPS on both ends). For local dev or same-domain deployment, leave 'false'.
CROSS_SITE_COOKIES=false
